# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (Required for some server-side cron jobs/admin scripts)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vercel Cron Secret (For authenticating cron job executions)
CRON_SECRET=your_cron_secret_here

# OpenAI API Key (Required for AI Ad Generator, optional if DEMO_MODE=true)
OPENAI_API_KEY=sk-your-openai-key-here

# Demo Mode Flag (Set to 'true' to use free demo mode for AI generation)
DEMO_MODE=false
